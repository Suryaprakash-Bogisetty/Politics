GROQ_API_KEY=your_groq_api_key_here

# Optional override — defaults to a current, non-decommissioned Groq model in config.py.
# Known-working: llama-3.3-70b-versatile (quality), llama-3.1-8b-instant (speed/cost).
# Do NOT use llama3-8b-8192 / llama3-70b-8192 — decommissioned.
GROQ_MODEL=llama-3.3-70b-versatile
